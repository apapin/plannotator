// Scoped Slice 4 verification config — typechecks only `hooks/useCollabRoom.ts`.
// Full `packages/ui` typecheck is intentionally deferred: the UI package has
// pre-existing type debt (strict-mode violations, missing CSS side-effect decls,
// bun:test lib gaps) unrelated to Slice 4. This config verifies the new hook
// without pulling that debt into a feature PR.
{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@plannotator/ui/*": ["./*"],
      "@plannotator/shared": ["../shared/index.ts"],
      "@plannotator/shared/*": ["../shared/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "hooks/useCollabRoom.ts"
  ]
}
